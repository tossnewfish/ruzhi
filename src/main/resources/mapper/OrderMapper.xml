<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.example.onboarding.mapper.OrderMapper">

    <resultMap id="OrderResultMap" type="com.example.onboarding.domain.OrderRecord">
        <id property="id" column="id"/>
        <result property="orderNo" column="order_no"/>
        <result property="productName" column="product_name"/>
        <result property="amount" column="amount"/>
        <result property="status" column="status"/>
        <result property="createdAt" column="created_at"/>
        <result property="updatedAt" column="updated_at"/>
    </resultMap>

    <sql id="OrderColumns">
        id, order_no, product_name, amount, status, created_at, updated_at
    </sql>

    <insert id="insert" parameterType="com.example.onboarding.domain.OrderRecord"
            useGeneratedKeys="true" keyProperty="id">
        INSERT INTO demo_order (order_no, product_name, amount, status)
        VALUES (#{orderNo}, #{productName}, #{amount}, #{status})
    </insert>

    <select id="selectById" resultMap="OrderResultMap">
        SELECT <include refid="OrderColumns"/>
        FROM demo_order
        WHERE id = #{id}
    </select>

    <select id="selectRecentCreated" resultMap="OrderResultMap">
        SELECT <include refid="OrderColumns"/>
        FROM demo_order
        WHERE status = 'CREATED'
        ORDER BY created_at DESC
        LIMIT #{limit}
    </select>

    <update id="updateStatus">
        UPDATE demo_order
        SET status = #{status}
        WHERE id = #{id}
    </update>
</mapper>
